{
  "name": "omnipizza-ai-harness",
  "version": "1.0.0",
  "description": "Referencia de AI Test Harness (Playwright + TypeScript) para el Modulo 07 sobre OmniPizza",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui-chromium",
    "test:api": "playwright test --project=api",
    "test:smoke": "playwright test --grep @smoke",
    "test:headed": "playwright test --project=ui-chromium --headed",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report",
    "install:browsers": "playwright install"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/node": "^20",
    "typescript": "^5.7",
    "dotenv": "^17"
  }
}
