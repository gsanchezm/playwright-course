{
  "name": "omnipizza-ai-harness",
  "version": "1.0.0",
  "description": "Harness E2E portable (Playwright + TypeScript) — referencia de la forma esperada del playbook de IA del Módulo 07 sobre OmniPizza",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui-chromium",
    "test:api": "playwright test --project=api",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/node": "^20",
    "typescript": "^5.7",
    "dotenv": "^17"
  }
}
