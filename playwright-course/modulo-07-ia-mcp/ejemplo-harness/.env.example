# ============================================================
# .env.example — variables de entorno del harness OmniPizza
# ============================================================
# Copia este archivo a `.env` (que está en .gitignore) y ajusta
# los valores si pruebas contra otro ambiente. env.ts (Singleton)
# las lee UNA sola vez al arrancar.
# ============================================================

# URL del frontend (UI tests)
BASE_URL=https://omnipizza-frontend.onrender.com

# URL del backend (API tests / servicios)
API_URL=https://omnipizza-backend.onrender.com

# Credenciales del usuario de prueba happy-path
TEST_USER_USERNAME=standard_user
TEST_USER_PASSWORD=pizza123

# Mercado por defecto (MX | US | CH | JP)
DEFAULT_COUNTRY=MX
