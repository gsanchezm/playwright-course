# ============================================================
# Ejemplo de workflow GitHub Actions para el framework OmniPizza
# ============================================================
# Copia este archivo a .github/workflows/playwright.yml de tu repo
# (con extensión .yml, no .yml.example).
# ============================================================

name: Playwright Tests

on:
  push:
    branches: [main, master]
  pull_request:
    branches: [main, master]

jobs:
  test:
    timeout-minutes: 30
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 20

      - name: Install pnpm
        uses: pnpm/action-setup@v3
        with:
          version: 9

      # Cache de pnpm store para acelerar runs posteriores
      - name: Get pnpm store directory
        id: pnpm-cache
        shell: bash
        run: |
          echo "STORE_PATH=$(pnpm store path --silent)" >> $GITHUB_OUTPUT

      - name: Setup pnpm cache
        uses: actions/cache@v4
        with:
          path: ${{ steps.pnpm-cache.outputs.STORE_PATH }}
          key: ${{ runner.os }}-pnpm-store-${{ hashFiles('**/pnpm-lock.yaml') }}
          restore-keys: |
            ${{ runner.os }}-pnpm-store-

      - name: Install dependencies
        run: pnpm install --frozen-lockfile

      # En CI solo instalamos Chromium para ahorrar minutos
      - name: Install Playwright browsers
        run: pnpm exec playwright install --with-deps chromium

      # Despertar OmniPizza backend (Render free tier)
      - name: Warm up OmniPizza backend
        run: |
          curl -f --max-time 60 https://omnipizza-backend.onrender.com/health || true
          curl -f --max-time 60 https://omnipizza-frontend.onrender.com/ || true
        continue-on-error: true

      # En PRs: solo smoke (~3 min). En push a main: sustituir por pnpm test
      - name: Run smoke tests
        run: pnpm test:smoke --project=chromium
        env:
          # Los usuarios deterministas de OmniPizza son PÚBLICOS en el curso.
          # En un proyecto real, aquí pondrías credenciales reales vía secrets:
          TEST_USER: ${{ secrets.TEST_USER }}
          TEST_PASS: ${{ secrets.TEST_PASS }}

      - name: Upload Playwright HTML report
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: playwright-report
          path: playwright-report/
          retention-days: 30

      - name: Upload test-results (traces, videos, screenshots)
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: test-results
          path: test-results/
          retention-days: 7

# ============================================================
# VARIANTE: shards en paralelo (suite grande)
# ============================================================
# Reemplaza el job "test" por:
#
#   test:
#     strategy:
#       fail-fast: false
#       matrix:
#         shard: [1/4, 2/4, 3/4, 4/4]
#     steps:
#       # ...checkout + setup...
#       - run: pnpm test --shard=${{ matrix.shard }} --project=chromium
#
# Esto arranca 4 jobs en paralelo. Requiere (en CI) el reporter "blob"
# y un job final que mergea los reports:
#   reporter: process.env.CI ? [['blob']] : [['html']]
# ============================================================
