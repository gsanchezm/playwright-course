{
  "name": "omnipizza-m04-setup-fixtures",
  "version": "1.0.0",
  "description": "Snapshot autocontenido de playwright_architecture al terminar el Modulo 04 (setup project + custom fixtures) sobre OmniPizza",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:setup": "playwright test --project=setup",
    "test:chromium": "playwright test --project=ui-chromium",
    "test:firefox": "playwright test --project=ui-firefox",
    "test:webkit": "playwright test --project=ui-webkit",
    "test:cross": "playwright test --project=ui-chromium --project=ui-firefox --project=ui-webkit",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report",
    "install:browsers": "playwright install",
    "m4": "playwright test --project=ui-chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/node": "^20.11.0",
    "dotenv": "^17.4.2",
    "typescript": "^5.7.0"
  }
}
