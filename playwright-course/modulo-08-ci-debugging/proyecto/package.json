{
  "name": "omnipizza-m08-ci-debugging",
  "version": "1.0.0",
  "description": "Snapshot autocontenido de playwright-course al terminar el Modulo 08 (CI + debugging) — framework completo sobre OmniPizza",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:smoke": "playwright test --grep @smoke",
    "test:api": "playwright test --project=api",
    "test:setup": "playwright test --project=setup",
    "test:chromium": "playwright test --project=ui-chromium",
    "test:firefox": "playwright test --project=ui-firefox",
    "test:webkit": "playwright test --project=ui-webkit",
    "test:cross": "playwright test --project=ui-chromium --project=ui-firefox --project=ui-webkit",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report",
    "codegen": "playwright codegen https://omnipizza-frontend.onrender.com",
    "install:browsers": "playwright install",
    "m1": "playwright test modulo-01-smoke-feo --project=ui-anon",
    "m2": "playwright test modulo-02-locators --project=ui-anon",
    "m3": "playwright test modulo-03-data-driven --project=ui-anon",
    "m4": "playwright test modulo-04-pom --project=ui-anon",
    "m5": "playwright test modulo-05-fixtures --project=ui-chromium",
    "m6": "playwright test modulo-06-setup --project=ui-chromium",
    "m7": "playwright test modulo-07-api-layer --project=api",
    "m8": "playwright test modulo-08-ci-debugging --project=ui-chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/node": "^20.11.0",
    "dotenv": "^17.4.2",
    "typescript": "^5.7.0"
  }
}
