{
  "name": "playwright-course",
  "version": "3.0.0",
  "description": "Curso de Playwright para QA Automation — arquitectura incremental sobre OmniPizza",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:api": "playwright test --project=api",
    "test:chromium": "playwright test --project=ui-chromium",
    "test:firefox": "playwright test --project=ui-firefox",
    "test:webkit": "playwright test --project=ui-webkit",
    "test:setup": "playwright test --project=setup",
    "codegen": "playwright codegen https://omnipizza-frontend.onrender.com",
    "report": "playwright show-report",
    "install-browsers": "playwright install",
    "typecheck": "tsc --noEmit",
    "m1": "playwright test modulo-01-smoke-feo --project=ui-chromium",
    "m2": "playwright test modulo-02-locators-data --project=ui-chromium",
    "m3": "playwright test modulo-03-pom --project=ui-chromium",
    "m4": "playwright test modulo-04-setup-fixtures --project=ui-chromium",
    "m5": "playwright test modulo-05-api-layer --project=api",
    "m6": "playwright test modulo-06-ci-debugging --project=ui-chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/node": "^20.11.0",
    "dotenv": "^17.4.2",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
