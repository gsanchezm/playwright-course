# ============================================================
# OmniPizza — Variables de entorno (versionadas como plantilla)
# ============================================================
# Copia este archivo a `.env` y ajusta los valores si fuera
# necesario. El `.env` real NUNCA se commitea (está en .gitignore).
# En GitHub Actions se inyectan vía `secrets.*` (ver M06).
# ============================================================

# URLs de OmniPizza (frontend y backend en Render free tier)
BASE_URL=https://omnipizza-frontend.onrender.com
API_URL=https://omnipizza-backend.onrender.com

# Credenciales del usuario de pruebas (deterministas en OmniPizza)
TEST_USER_USERNAME=standard_user
TEST_USER_PASSWORD=pizza123

# Mercado por defecto (MX | US | CH | JP)
DEFAULT_COUNTRY=MX
